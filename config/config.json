      "baseUrl": "http://cve-lookup-tool:8080",
      "endpoints": {
        "lookup": "/cve/lookup",
        "bulkLookup": "/cve/bulk-lookup",
        "health": "/health"
      },
      "timeoutMs": 30000
    },
    {
      "name": "git_ops_tool",
      "class": "GitOpsTool",
      "type": "api",
      "baseUrl": "http://git-ops-tool:8080",
      "localFallbackUrl": "http://localhost:4100",
      "endpoints": {
        "createBranch": "/git/branch",
        "commitPatch": "/git/commit",
        "checkFileExists": "/git/file-exists",
        "openPullRequest": "/git/pull-request",
        "health": "/health"
      },
      "timeoutMs": 60000
    },
    {
      "name": "verification_scan_tool",
      "class": "VerificationScanTool",
      "type": "api",
      "baseUrl": "http://verification-scan-tool:8080",
      "endpoints": {
        "verifyFix": "/verify",
        "health": "/health"
      },
      "timeoutMs": 120000
    },
    {
      "name": "notification_tool",
      "class": "NotificationTool",
      "type": "api",
      "baseUrl": "http://notification-tool:8080",
      "endpoints": {
        "sendSlack": "/notify/slack",
        "sendEmail": "/notify/email",
        "sendDigest": "/notify/digest",
        "health": "/health"
      },
      "timeoutMs": 30000
    },
    {
      "name": "report_generator_tool",
      "class": "ReportGeneratorTool",
      "type": "api",
      "baseUrl": "http://report-generator-tool:8080",
      "endpoints": {
        "generateExecutiveSummary": "/reports/executive-summary",
        "generateHtml": "/reports/html",
        "health": "/health"
      },
      "timeoutMs": 60000
    },
    {
      "name": "report_generator_tool_shared",
      "class": "ReportGeneratorTool",
      "type": "api",
      "baseUrl": "http://report-generator-tool:8080",
      "endpoints": {
        "generateExecutiveSummary": "/reports/executive-summary",
        "generateHtml": "/reports/html",
        "health": "/health"
      },
      "timeoutMs": 60000
    },
    {
      "name": "trivy_scan_tool",
      "class": "TrivyScanTool",
      "type": "api",
      "baseUrl": "http://trivy-scan-tool:8080",
      "localFallbackUrl": "http://localhost:4140",
      "endpoints": {
        "scan": "/trivy/scan",
        "repo": "/trivy/repo",
        "image": "/trivy/image",
        "config": "/trivy/config",
        "sbom": "/trivy/sbom",
        "health": "/health"
      },
      "dedupe": {
        "enabled": true,
        "key": "canonical_cve_id"
      },
      "timeoutMs": 300000
    },
    {
      "name": "renovate_fix_tool",
